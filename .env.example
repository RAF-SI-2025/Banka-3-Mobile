# Expo embeds EXPO_PUBLIC_* into the JS bundle at build time.
#
# Point this at the gateway REST surface. The gateway listens on :8080
# and the public API is under /v1 (this base ends at /api; the client
# appends /v1/...). On a physical device / emulator this MUST be the
# dev machine's LAN IP, NOT localhost — the phone resolves localhost to
# itself. Android emulator can use http://10.0.2.2:8080/api.
#
# Copy this file to .env and adjust the IP.
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.14:8080/api
